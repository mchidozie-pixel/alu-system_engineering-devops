#!/usr/bin/env bash
# Installs and configures HAProxy to distribute traffic to web-01 and web-02 using roundrobin

# Update package list and install HAProxy
apt-get update -y
apt-get install -y haproxy

# Enable HAProxy to be started by init script
echo "ENABLED=1" | tee /etc/default/haproxy > /dev/null

# Configure HAProxy
# Note: Using your ID 7010 and the IPs provided in your initial prompt
tee /etc/haproxy/haproxy.cfg > /dev/null <<EOF
global
    log /dev/log local0
    log /dev/log local1 notice
    chroot /var/lib/haproxy
    stats socket /run/haproxy/admin.sock mode 660 level admin
    stats timeout 30s
    user haproxy
    group haproxy
    daemon

defaults
    log     global
    mode    http
    option  httplog
    option  dontlognull
    timeout connect 5000
    timeout client  50000
    timeout server  50000

frontend http_front
    bind *:80
    default_backend http_back

backend http_back
    balance roundrobin
    server 7010-web-01 44.201.79.14:80 check
    server 7010-web-02 3.86.212.68:80 check
EOF

# Restart HAProxy to apply configuration
service haproxy restart
