#!/usr/bin/env bash
# Configures a brand new Ubuntu server to add a custom HTTP response header X-Served-By
# The header contains the server hostname (web-01 or web-02) for load balancer tracking

# Exit immediately if a command fails
set -e

# ----------------------------
# 1. Set hostname for the server
# ----------------------------
# Change <STUDENT_ID> to your actual student ID
STUDENT_ID="6973"

# Detect if this is web-01 or web-02 based on an argument or existing hostname
# You can call the script with argument: ./0-custom_http_response_header web-01
if [ "$1" == "web-01" ]; then
    TARGET_HOSTNAME="${STUDENT_ID}-web-01"
elif [ "$1" == "web-02" ]; then
    TARGET_HOSTNAME="${STUDENT_ID}-web-02"
else
    echo "Please run the script with argument 'web-01' or 'web-02'"
    exit 1
fi

# Set the hostname
sudo hostnamectl set-hostname "$TARGET_HOSTNAME"

# ----------------------------
# 2. Install Nginx
# ----------------------------
sudo apt-get update -y
sudo apt-get install -y nginx

# ----------------------------
# 3. Add custom HTTP header X-Served-By
# ----------------------------
# Use conf.d folder for cleanliness
sudo bash -c "cat > /etc/nginx/conf.d/custom_header.conf <<EOL
add_header X-Served-By \"$TARGET_HOSTNAME\";
EOL"

# ----------------------------
# 4. Allow HTTP and SSH through firewall
# ----------------------------
sudo ufw allow 'Nginx HTTP'
sudo ufw allow 'OpenSSH'
sudo ufw --force enable

# ----------------------------
# 5. Test Nginx config and restart
# ----------------------------
sudo nginx -t
sudo systemctl restart nginx

# ----------------------------
# 6. Output info for verification
# ----------------------------
echo "Server hostname: $TARGET_HOSTNAME"
echo "X-Served-By header configured. Test with:"
echo "curl -sI http://<server-IP> | grep X-Served-By"
